# Copy this file to `.env` and adjust for your deployment.

# Base URL of the oncothresh-web backend.
VITE_API_BASE=http://localhost:8000

# --- Domain labels (optional) -------------------------------------------------
# oncothresh-web is domain-agnostic. Leave these blank for generic wording, or set
# them to specialise the copy to your use case (e.g. tumour cellularity).

# Short unit appended after the percentage readout, e.g. "cellularity" -> "20% cellularity".
VITE_SCORE_UNIT=

# A concrete example sentence shown in the threshold explainer.
VITE_EXAMPLE_USE_CASE=
